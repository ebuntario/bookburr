# =============================================================================
# BookBurr Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# --- Required ---

# Neon PostgreSQL pooled connection string (must include sslmode=require)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth JWT secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Resend API key for magic link emails (https://resend.com)
AUTH_RESEND_KEY=

# Full auth URL (http://localhost:3000 for local dev)
AUTH_URL=http://localhost:3000

# --- Optional ---

# From address for magic link emails (defaults to "BookBurr <noreply@bookburr.com>")
# AUTH_EMAIL_FROM=BookBurr <noreply@bookburr.com>

# Public base URL for share links (defaults to https://bookburr.com)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google Places API key for venue discovery
# GOOGLE_PLACES_API_KEY=

# Upstash Redis for rate limiting (optional — gracefully degrades without)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Supabase Realtime (optional — gracefully degrades without)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- E2E Testing Only ---
# Set to "true" to enable test-only credentials provider (never set in production)
# E2E_TEST=true
